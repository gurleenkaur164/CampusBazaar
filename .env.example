# Supabase — from your project's Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Restrict sign-ups to your campus domain (the part after the @)
NEXT_PUBLIC_ALLOWED_EMAIL_DOMAIN=university.edu

# Free Google Gemini API key for the Listing Assistant Agent
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
